# Claude API
ANTHROPIC_API_KEY=

# LINE
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# System Admins (comma-separated LINE userIds)
# Falls back to ADMIN_USER_IDS if not set
SYSTEM_ADMIN_IDS=Uadmin1,Uadmin2

# Users
USER_STORE_PATH=data/users.json                       # optional
WORKSPACE_STORE_PATH=data/workspaces.json              # optional
PENDING_ACTION_STORE_PATH=data/pending-actions.json    # optional
WORKSPACE_DATA_DIR=data/workspaces                     # optional

# MCP Pool
MCP_POOL_SIZE=3                                        # optional, default: 3
# PUPPETEER_EXECUTABLE_PATH=                            # Docker: 자동 설정. 로컬: 미설정 시 Puppeteer 기본값

# Logging
LOG_LEVEL=                                             # optional: debug/info/warning/error, default: info
DEBUG=                                                 # optional: 1 or true → debug level (LOG_LEVEL takes priority)

# Server
PORT=3000

# Cloudflare Tunnel
CF_TUNNEL_TOKEN=
